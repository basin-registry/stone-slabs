import sqrt from math

export fn double(x) = x * 2

export fn square(x) = x * x

export fn hypotenuse(a, b) = sqrt(a * a + b * b)

export fn sum_array(xs) {
  total := evolve { total = 0 } for (x in xs) {
    total' = total + x
  }
  return(total)
}

export fn scale_array(xs, factor) {
  result[i] = xs[i] * factor
  return(result)
}
